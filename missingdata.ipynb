import numpy as np
import pandas as pd
data = {
    'A':[1,2,np.nan,4,5],
    'B':[1,2,3,4,5],
    'C':[1,2,3,np.nan,np.nan],
    'D':[1,np.nan,np.nan,np.nan,5]
}
df = pd.DataFrame(data)
df
df.isna().sum()
df.isna().any()
df
df.dropna()
df
df.dropna(thresh=2)
## filling the missing data ##
df
df.fillna(0)
df
values = {'A':550,'B':100,'C':200,'D':300}
df.fillna(value = values)
df
df.fillna(df.mean())
